{
    "name": "spark/framework",
    "description": "Spark — a lightweight Laravel-inspired PHP framework",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Spark\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/Support/helpers.php"
        ]
    },
    "bin": [
        "spark"
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}

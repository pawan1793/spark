{
    "name": "spark/framework",
    "description": "Spark — a lightweight, Laravel-inspired PHP framework with routing, ORM, templating, and CLI",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "framework",
        "php",
        "mvc",
        "orm",
        "router",
        "spark",
        "micro-framework"
    ],
    "authors": [
        {
            "name": "Pawan More",
            "email": "hello@pawanmore.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/pawan1793/spark",
    "support": {
        "issues": "https://github.com/pawan1793/spark/issues",
        "source": "https://github.com/pawan1793/spark"
    },
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Spark\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Spark\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/spark"
    ],
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    },
    "extra": {
        "spark": {
            "dont-discover": []
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
